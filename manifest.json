{
  "manifest_version": 3,
  "name": "AutoFair",
  "version": "0.2.0",
  "description": "Know if the price is fair before you buy. Price analysis for Avto.net and mobile.de by FlegarTech.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://www.avto.net/*",
    "https://avto.net/*",
    "https://suchen.mobile.de/*",
    "https://www.mobile.de/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "assets/logo-16.png",
    "32": "assets/logo-32.png",
    "48": "assets/logo-48.png",
    "128": "assets/logo-128.png"
  },
  "action": {
    "default_title": "AutoFair",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/logo-16.png",
      "32": "assets/logo-32.png",
      "48": "assets/logo-48.png",
      "128": "assets/logo-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.avto.net/*",
        "https://avto.net/*",
        "https://suchen.mobile.de/*",
        "https://www.mobile.de/*"
      ],
      "css": [
        "styles/panel.css"
      ],
      "js": [
        "lib/constants.js",
        "lib/i18n.js",
        "lib/utils.js",
        "lib/selectors.js",
        "lib/parsing.js",
        "lib/comparables.js",
        "lib/pricing.js",
        "lib/descriptionSignals.js",
        "lib/scoring.js",
        "lib/storage.js",
        "panel.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/logo.svg"
      ],
      "matches": [
        "https://www.avto.net/*",
        "https://avto.net/*",
        "https://suchen.mobile.de/*",
        "https://www.mobile.de/*"
      ]
    }
  ]
}
